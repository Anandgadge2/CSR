datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserAccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
  PENDING_APPROVAL
  PENDING_ACTIVATION
}

enum OrganizationKind {
  NGO
  CSR_COMPANY
  GOVERNMENT_DEPARTMENT
  PORTAL_ADMIN_ORG
}

enum OrganizationStatus {
  REGISTERED
  PROFILE_INCOMPLETE
  DOCUMENTS_PENDING
  UNDER_VERIFICATION
  CLARIFICATION_REQUIRED
  ACTIVE
  REJECTED
  SUSPENDED
}

enum ProjectType {
  NGO_PROPOSAL
  MARKETPLACE_REQUIREMENT
  CONVERGENCE_FRAMEWORK
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  MARKETPLACE_LISTED
  AGREEMENT_SIGNED
  EXECUTION_STARTED
  IN_PROGRESS
  COMPLETED
  REJECTED
  CANCELLED
  FUNDED
}

enum MilestoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED_FOR_VERIFICATION
  APPROVED
  RELEASED
  REJECTED
}

enum VerificationModuleType {
  GST
  AADHAAR
  PAN
  CIN
  UDYAM
  DIGILOCKER
}

enum VerificationRecordStatus {
  IN_PROGRESS
  OTP_SENT
  SUCCESS
  FAILED
  EXPIRED
}

enum PaymentStatus {
  CREATED
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
}

enum GrievanceStatus {
  RAISED
  ACKNOWLEDGED
  LEVEL_1_REVIEW
  LEVEL_1_RESOLVED
  ESCALATED_TO_STATE_CELL
  LEVEL_2_RESOLVED
  ESCALATED_TO_JS_SECRETARY
  CLOSED
  REJECTED
}

enum FeasibilityResult {
  FEASIBLE
  PROCEED_WITH_CONDITIONS
  NOT_FEASIBLE
}

enum ChecklistAnswer {
  YES
  NO
  NA
}

// =============================================================================
// USER, ROLE & ACCESS CONTROL ENGINE
// =============================================================================

model User {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  accountStatus     UserAccountStatus @default(PENDING_ACTIVATION)
  isVerified        Boolean           @default(false)
  
  // Basic Metadata
  firstName         String?
  lastName          String?
  mobile            String?           @unique

  // Primary Role Reference (Strict Integer ID: 1-9 for System Roles, 10+ for Dynamic Roles)
  roleId            Int?
  role              Role?             @relation("UserPrimaryRole", fields: [roleId], references: [id], onDelete: SetNull)

  // Organization Context
  organizationId    String?
  organization      Organization?     @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Sub-login Hierarchy
  parentUserId      String?
  parentUser        User?             @relation("UserHierarchy", fields: [parentUserId], references: [id], onDelete: SetNull)
  subUsers          User[]            @relation("UserHierarchy")

  // Soft Delete & Timestamps
  deletedAt         DateTime?
  deletedById       String?
  deleteReason      String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // System Relations
  userRoles         UserOrganizationRole[]
  officerProfile    UserOfficerProfile?
  districtMappings  DistrictNodalMapping[] @relation("NodalUser")
  assignedByMappings DistrictNodalMapping[] @relation("AssignedByNodalUser")
  sessions          Session[]
  auditLogs         AuditLog[]        @relation("ActorAuditLogs")
  
  // Workflow Relations
  assignedProjects  ProjectAssignment[] @relation("AssignedToUser")
  givenAssignments  ProjectAssignment[] @relation("AssignedByUser")
  grievancesRaised  Grievance[]         @relation("GrievancesRaised")
  grievanceLogs     GrievanceActionLog[] @relation("GrievanceActor")
  inspections       ProjectInspection[] @relation("InspectorUser")
  helpdeskRaised    HelpdeskQuery[]     @relation("HelpdeskRaised")
  helpdeskResolved  HelpdeskQuery[]     @relation("HelpdeskResolved")
  verificationRecords VerificationRecord[] @relation("InitiatedBy")
  messages          Message[]

  @@index([organizationId])
  @@index([roleId])
  @@index([parentUserId])
  @@index([email, accountStatus])
  @@index([roleId, organizationId])
  @@index([accountStatus])
  @@index([createdAt])
}

// Role Entity using Strict Integer IDs (1-9 System Roles, 10+ Dynamic Custom Roles, NO SLUG)
model Role {
  id             Int                    @id @default(autoincrement())
  name           String
  description    String?
  isSystemRole   Boolean                @default(false)
  isProtected    Boolean                @default(false)
  
  organizationId String?
  organization   Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  users          User[]                 @relation("UserPrimaryRole")
  userRoles      UserOrganizationRole[]
  rolePermissions RolePermission[]
  parentRoles    RoleHierarchy[]        @relation("ParentRoleHierarchy")
  childRoles     RoleHierarchy[]        @relation("ChildRoleHierarchy")
  projectAssignments ProjectAssignment[]

  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([isSystemRole])
}

model Permission {
  id              String           @id @default(uuid())
  key             String           @unique
  description     String?
  module          String
  createdAt       DateTime         @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model RoleHierarchy {
  id           String   @id @default(uuid())
  parentRoleId Int
  childRoleId  Int
  parentRole   Role     @relation("ParentRoleHierarchy", fields: [parentRoleId], references: [id], onDelete: Cascade)
  childRole    Role     @relation("ChildRoleHierarchy", fields: [childRoleId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([parentRoleId, childRoleId])
  @@index([parentRoleId])
  @@index([childRoleId])
}

model UserOrganizationRole {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId         Int
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime      @default(now())

  @@unique([userId, roleId, organizationId])
  @@index([userId])
  @@index([roleId])
  @@index([organizationId])
}

model UserOfficerProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName       String
  employeeId     String?  @unique
  designation    String?
  department     String?
  district       String?
  taluka         String?
  officeAddress  String?
  mobile         String?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([district])
  @@index([employeeId])
}

// =============================================================================
// UNIFIED ORGANIZATION ENGINE
// =============================================================================

model Organization {
  id                 String             @id @default(uuid())
  kind               OrganizationKind
  name               String
  legalName          String?
  displayName        String?
  registrationNumber String?            @unique
  cin                String?            @unique
  pan                String?            @unique
  gstin              String?            @unique
  
  // Contact & Location
  officialEmail      String?
  officialPhone      String?
  website            String?
  address            String?
  state              String             @default("Maharashtra")
  district           String?
  taluka             String?
  pincode            String?

  status             OrganizationStatus @default(REGISTERED)

  // Specialized 1:1 Extension Profiles
  csrCompanyProfile  CSRCompanyProfile?
  ngoProfile         NGOProfile?
  govDeptProfile     GovDepartmentProfile?

  // System Relations
  users              User[]
  projects           Project[]          @relation("OrganizationProjects")
  documents          Document[]
  bankAccounts       BankAccount[]
  roles              Role[]
  userRoles          UserOrganizationRole[]

  // Soft Delete & Timestamps
  deletedAt          DateTime?
  deletedById        String?
  deleteReason       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([kind])
  @@index([status])
  @@index([district])
  @@index([kind, status])
  @@index([officialEmail])
  @@index([createdAt])
}

model CSRCompanyProfile {
  id                       String       @id @default(uuid())
  organizationId           String       @unique
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  csrRegistrationNo        String?
  annualCsrBudget          Decimal?     @db.Decimal(15, 2)
  netWorth                 Decimal?     @db.Decimal(15, 2)
  turnover                 Decimal?     @db.Decimal(15, 2)
  netProfit                Decimal?     @db.Decimal(15, 2)
  twoPercentCsrObligation  Decimal?     @db.Decimal(15, 2)

  preferredDistricts       String[]
  preferredSectors         String[]
  
  csrHeadName              String?
  csrHeadEmail             String?
  csrHeadMobile            String?

  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
}

model NGOProfile {
  id                     String       @id @default(uuid())
  organizationId         String       @unique
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  darpanNumber           String?      @unique
  csr1Number             String?      @unique
  certificate12AUrl      String?
  certificate80GUrl      String?
  fcraDetails            String?
  
  yearEstablished        Int?
  areasOfOperation       String[]
  csrSectors             String[]
  impactStatistics       Json?

  riskScores             RiskScore[]

  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
}

model GovDepartmentProfile {
  id                      String       @id @default(uuid())
  organizationId          String       @unique
  organization            Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  departmentType          String?
  parentDepartment        String?
  departmentCode          String?
  
  nodalOfficerName        String?
  nodalOfficerDesignation String?
  nodalOfficerEmail       String?
  nodalOfficerMobile      String?

  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
}

// =============================================================================
// UNIFIED PROJECT ENGINE
// =============================================================================

model Project {
  id                       String             @id @default(uuid())
  projectCode              String             @unique
  type                     ProjectType        @default(CONVERGENCE_FRAMEWORK)
  
  title                    String
  description              String             @db.Text
  sector                   String
  focusArea                String?
  sdgGoals                 String[]
  
  // Location
  state                    String             @default("Maharashtra")
  district                 String
  taluka                   String
  village                  String?
  latitude                 Float?
  longitude                Float?

  // Financial Precision
  approvedBudget           Decimal            @db.Decimal(15, 2)
  budgetRequested          Decimal?           @db.Decimal(15, 2)
  committedAmount          Decimal            @default(0) @db.Decimal(15, 2)
  utilizedAmount           Decimal            @default(0) @db.Decimal(15, 2)
  
  // Beneficiaries
  beneficiaryCount         Int                @default(0)
  beneficiariesSummary     String?            @db.Text

  status                   ProjectStatus      @default(DRAFT)
  
  // Ownership linkages
  organizationId           String
  organization             Organization       @relation("OrganizationProjects", fields: [organizationId], references: [id], onDelete: Restrict)
  
  corporatePartnerId       String?
  implementingAgencyId     String?
  ngoId                    String?
  nodalOfficerUserId       String?

  // Lifecycle Dates
  startDate                DateTime?
  expectedEndDate          DateTime?
  completedAt              DateTime?

  // Soft Delete & Timestamps
  deletedAt                DateTime?
  deletedById              String?
  deleteReason             String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  // Child Relations
  milestones               ProjectMilestone[]
  inspections              ProjectInspection[]
  documents                Document[]
  utilizationCertificates UtilizationCertificate[]
  grievances               Grievance[]
  mou                      StandardMou?
  agreements               Agreement[]

  @@index([district, sector])
  @@index([status])
  @@index([organizationId])
  @@index([type])
  @@index([status, type])
  @@index([nodalOfficerUserId])
  @@index([corporatePartnerId])
  @@index([implementingAgencyId])
  @@index([createdAt])
}

model ProjectMilestone {
  id                   String                  @id @default(uuid())
  projectId            String
  project              Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name                 String
  description          String?                 @db.Text
  targetAmount         Decimal                 @db.Decimal(15, 2)
  utilizedAmount       Decimal                 @default(0) @db.Decimal(15, 2)
  
  dueDate              DateTime?
  status               MilestoneStatus         @default(NOT_STARTED)
  geoTaggedPhotoUrls   String[]

  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  utilizationCertificates UtilizationCertificate[]

  @@index([projectId])
  @@index([status])
}

// =============================================================================
// UNIFIED DOCUMENT MANAGEMENT
// =============================================================================

model Document {
  id                 String             @id @default(uuid())
  title              String
  documentType       String
  fileUrl            String
  fileName           String
  fileSize           Int
  fileType           String
  fileHash           String?
  
  // Scoped Entity Linkages
  organizationId     String?
  organization       Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  projectId          String?
  project            Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Verification Audit
  verificationStatus String             @default("UPLOADED")
  verifiedByUserId   String?
  verifiedAt         DateTime?
  rejectionReason    String?

  uploadedByUserId   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([organizationId])
  @@index([projectId])
  @@index([documentType])
  @@index([verificationStatus])
}

// =============================================================================
// VERIFICATION, RISK & AUDIT
// =============================================================================

model VerificationRecord {
  id               String                   @id @default(uuid())
  entityType       String
  entityId         String
  verificationType VerificationModuleType
  status           VerificationRecordStatus @default(IN_PROGRESS)
  attempt          Int                      @default(1)
  isLatest         Boolean                  @default(true)
  
  maskedIdentifier String?
  requestId        String                   @unique @default(uuid())
  transactionId    String?                  
  responseData     Json?
  encryptedPayload String?                  @db.Text
  
  errorCode        String?
  errorMessage     String?
  responseTimeMs   Int?
  expiresAt        DateTime?
  source           String?
  
  initiatedById    String?
  initiatedBy      User?                    @relation("InitiatedBy", fields: [initiatedById], references: [id], onDelete: SetNull)

  verifiedAt       DateTime?
  createdAt        DateTime                 @default(now())

  @@index([entityType, entityId, isLatest])
  @@index([transactionId])
  @@index([initiatedById])
}

model RiskScore {
  id                     String     @id @default(uuid())
  organizationId         String
  organization           NGOProfile @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  overallScore           Int
  riskLevel              String
  
  legalRegistrationScore Int        @default(0)
  financialScore         Int        @default(0)
  complianceScore        Int        @default(0)
  governanceScore        Int        @default(0)
  
  calculatedAt           DateTime   @default(now())
  riskFlags              RiskFlag[]

  @@index([organizationId])
}

model RiskFlag {
  id          String    @id @default(uuid())
  riskScoreId String
  riskScore   RiskScore @relation(fields: [riskScoreId], references: [id], onDelete: Cascade)
  
  flagType    String
  severity    String
  description String
  isResolved  Boolean   @default(false)
  resolvedAt  DateTime?

  createdAt   DateTime  @default(now())

  @@index([riskScoreId])
}

// =============================================================================
// FINANCIAL TRANSACTIONS & UTILIZATION
// =============================================================================

model BankAccount {
  id                 String       @id @default(uuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  accountHolderName  String
  bankName           String
  branchName         String
  accountNumber      String
  ifscCode           String
  accountType        String
  
  isPrimary          Boolean      @default(false)
  isVerified         Boolean      @default(false)
  cancelledChequeUrl String?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  paymentOrders      PaymentOrder[]

  @@index([organizationId])
  @@index([accountNumber])
}

model PaymentOrder {
  id               String        @id @default(uuid())
  orderNumber      String        @unique
  bankAccountId    String?
  bankAccount      BankAccount?  @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  
  amount           Decimal       @db.Decimal(15, 2)
  currency         String        @default("INR")
  purpose          String
  status           PaymentStatus @default(CREATED)
  
  gatewayName      String?
  gatewayOrderId   String?
  idempotencyKey   String        @unique

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([orderNumber])
  @@index([status])
  @@index([bankAccountId])
}

model UtilizationCertificate {
  id                   String            @id @default(uuid())
  projectId            String
  project              Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  milestoneId          String?
  milestone            ProjectMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  certificateUrl       String
  amountUtilized       Decimal           @db.Decimal(15, 2)
  remarks              String?           @db.Text
  
  verificationStatus   String            @default("PENDING")
  verifiedByUserId     String?
  verifiedAt           DateTime?

  uploadedAt           DateTime          @default(now())

  @@index([projectId])
  @@index([milestoneId])
  @@index([verificationStatus])
}

// =============================================================================
// WORKFLOW, GRIEVANCE & GOVERNANCE
// =============================================================================

model Grievance {
  id                  String               @id @default(uuid())
  grievanceCode       String               @unique
  projectId           String
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  raisedByUserId      String
  raisedByUser        User                 @relation("GrievancesRaised", fields: [raisedByUserId], references: [id], onDelete: Cascade)
  
  issueTitle          String
  issueDescription    String               @db.Text
  status              GrievanceStatus      @default(RAISED)
  
  resolutionText      String?              @db.Text
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  actionLogs          GrievanceActionLog[]

  @@index([projectId])
  @@index([status])
  @@index([raisedByUserId])
}

model GrievanceActionLog {
  id           String    @id @default(uuid())
  grievanceId  String
  grievance    Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)

  actorUserId  String
  actorUser    User      @relation("GrievanceActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  action       String
  note         String    @db.Text

  createdAt    DateTime  @default(now())

  @@index([grievanceId])
  @@index([actorUserId])
}

model ProjectInspection {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  inspectorUserId   String
  inspectorUser     User     @relation("InspectorUser", fields: [inspectorUserId], references: [id], onDelete: Cascade)

  visitDate         DateTime @default(now())
  latitude          Float?
  longitude         Float?
  geoTaggedImages   String[]
  
  remarks           String?  @db.Text
  issuesFound       String?  @db.Text
  actionRequired    String?  @db.Text

  createdAt         DateTime @default(now())

  @@index([projectId])
  @@index([inspectorUserId])
}

model StandardMou {
  id                          String   @id @default(uuid())
  mouReferenceId              String   @unique
  projectId                   String   @unique
  project                     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  financialContribution       Decimal  @db.Decimal(15, 2)
  governmentContribution      Decimal? @db.Decimal(15, 2)
  signedDocumentUrl           String?
  status                      String   @default("DRAFT")
  
  districtDepartmentName      String?
  nodalOfficerName            String?
  corporateName               String?
  cin                         String?
  projectTitle                String?
  projectDescription          String?  @db.Text
  scheduleVIIClause           String?
  projectLocation             String?
  timelineMonths              Int?
  implementationMode          String?
  ownershipAfterCompletion    String?
  maintenanceResponsibility   String?
  implementingAgencyName      String?
  corporateEnquiryId          String?
  governmentPitchId           String?
  deliverables                Json?

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ProjectAssignment {
  id             String   @id @default(uuid())
  entityType     String
  entityId       String
  assignmentType String
  
  assignedById   String
  assignedBy     User     @relation("AssignedByUser", fields: [assignedById], references: [id], onDelete: Restrict)
  
  assignedToId   String
  assignedTo     User     @relation("AssignedToUser", fields: [assignedToId], references: [id], onDelete: Cascade)
  
  assignedRoleId Int?
  assignedRole   Role?    @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)

  status         String   @default("ACTIVE")
  assignedAt     DateTime @default(now())

  @@index([entityId, entityType])
  @@index([assignedToId])
  @@index([assignedById])
  @@index([assignedRoleId])
}

model DistrictNodalMapping {
  id           String   @id @default(uuid())
  district     String
  domain       String?
  userId       String
  user         User     @relation("NodalUser", fields: [userId], references: [id], onDelete: Cascade)
  
  assignedById String
  assignedBy   User     @relation("AssignedByNodalUser", fields: [assignedById], references: [id], onDelete: Restrict)

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([district, isActive])
  @@index([userId])
  @@index([assignedById])
}

model HelpdeskQuery {
  id               String    @id @default(uuid())
  trackingId       String    @unique
  subject          String
  message          String    @db.Text
  name             String
  email            String
  mobile           String?

  status           String    @default("OPEN")
  resolution       String?   @db.Text

  raisedByUserId   String?
  raisedByUser     User?     @relation("HelpdeskRaised", fields: [raisedByUserId], references: [id], onDelete: SetNull)

  resolvedByUserId String?
  resolvedByUser   User?     @relation("HelpdeskResolved", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  resolutionDueAt  DateTime
  resolvedAt       DateTime?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@index([email])
  @@index([raisedByUserId])
  @@index([resolvedByUserId])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  userId      String?
  actorUser   User?    @relation("ActorAuditLogs", fields: [actorUserId], references: [id], onDelete: SetNull)
  
  action      String
  entityType  String?
  entityId    String?
  details     Json
  ipAddress   String?

  createdAt   DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model Session {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent       String?
  ipAddress       String?
  lastActivityIp  String?
  lastActivity    DateTime?
  expiry          DateTime?
  expiresAt       DateTime
  isRevoked       Boolean   @default(false)
  revokedByUserId String?

  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([isRevoked])
}

// =============================================================================
// SUPPLEMENTARY OPERATIONAL & MESSAGING ENGINE
// =============================================================================

model Notification {
  id          String   @id @default(uuid())
  recipientId String?
  userId      String?
  title       String
  message     String   @db.Text
  type        String   @default("INFO")
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId])
  @@index([userId])
  @@index([isRead])
}

model NotificationLog {
  id                String    @id @default(uuid())
  notificationId    String?
  recipientId       String?
  channel           String
  recipient         String
  status            String    @default("PENDING")
  error             String?
  providerMessageId String?
  retryCount        Int       @default(0)
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  @@index([recipient])
  @@index([status])
}

model NotificationTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  emailBody String?  @db.Text
  channels  String[]
  createdAt DateTime @default(now())
}

model OtpVerification {
  id         String   @id @default(uuid())
  identifier String
  otpHash    String
  expiresAt  DateTime
  verified   Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([identifier])
}

model PlatformSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

model SLAEscalation {
  id                String    @id @default(uuid())
  entityType        String
  entityId          String
  stage             String
  status            String    @default("ACTIVE")
  dueDate           DateTime
  dueAt             DateTime?
  responsibleUserId String?
  escalatedToUserId String?
  isResolved        Boolean   @default(false)
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([isResolved])
}

model WorkflowDefinition {
  id        String   @id @default(uuid())
  name      String   @unique
  stages    Json
  createdAt DateTime @default(now())
}

model WorkflowInstance {
  id             String   @id @default(uuid())
  entityType     String
  entityId       String
  currentStage   String
  currentStageId String?
  definitionId   String
  createdAt      DateTime @default(now())

  @@index([entityType, entityId])
}

model WorkflowHistory {
  id             String   @id @default(uuid())
  instanceId     String
  fromStage      String
  fromStageId    String?
  toStage        String
  toStageId      String?
  actionByUserId String?
  note           String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([instanceId])
}

model WorkflowTransition {
  id                 String  @id @default(uuid())
  definitionId       String
  fromStage          String
  toStage            String
  requiredRole       String?
  requiredPermission String?
  conditions         Json?

  @@index([definitionId])
}

model WorkflowRule {
  id                 String  @id @default(uuid())
  name               String
  stageId            String?
  actionType         String?
  requiredPermission String?
  template           String?
  conditions         Json
  actions            Json
}

model WorkflowAssignmentRule {
  id                 String  @id @default(uuid())
  district           String
  role               String
  assigneeUserId     String
  requiredPermission String?
  strategy           String?

  @@index([district])
}

model CorporateEnquiry {
  id                            String   @id @default(uuid())
  trackingId                    String?  @unique
  organizationId                String?
  corporateName                 String
  contactEmail                  String
  status                        String   @default("PENDING")
  assignedRelationshipManagerId String?
  createdAt                     DateTime @default(now())

  @@index([organizationId])
  @@index([assignedRelationshipManagerId])
  @@index([status])
  @@index([createdAt])
}

model GovernmentPitch {
  id                            String   @id @default(uuid())
  pitchReferenceId              String?  @unique
  departmentId                  String?
  title                         String
  budget                        Decimal  @db.Decimal(15, 2)
  status                        String   @default("PENDING")
  assignedRelationshipManagerId String?
  createdAt                     DateTime @default(now())

  @@index([departmentId])
  @@index([assignedRelationshipManagerId])
  @@index([status])
  @@index([createdAt])
}

model CorporatePitchInterest {
  id                  String   @id @default(uuid())
  interestTrackingId  String?  @unique
  pitchId             String
  corporateId         String
  status              String   @default("INTERESTED")
  createdAt           DateTime @default(now())

  @@index([pitchId])
  @@index([corporateId])
}

model NgoInvitation {
  id        String   @id @default(uuid())
  ngoId     String?
  email     String
  token     String   @unique
  status    String   @default("PENDING")
  createdAt DateTime @default(now())

  @@index([email])
}

model UserInvitation {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  status    String   @default("PENDING")
  roleId    Int?
  createdAt DateTime @default(now())

  @@index([email])
}

model Agreement {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      String    @default("DRAFT")
  documentUrl String?
  signedAt    DateTime?
  createdAt   DateTime  @default(now())

  @@index([projectId])
}

model MatchScore {
  id             String   @id @default(uuid())
  organizationId String
  projectId      String
  score          Float
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([projectId])
}

model Chat {
  id        String   @id @default(uuid())
  title     String?
  projectId String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  messages  Message[]

  @@index([projectId])
}

model Message {
  id           String   @id @default(uuid())
  chatId       String
  chat         Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderUserId String?
  senderId     String?
  sender       User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)
  content      String   @db.Text
  readBy       String[]
  createdAt    DateTime @default(now())

  @@index([chatId])
  @@index([senderUserId])
}
