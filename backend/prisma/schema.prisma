generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                    @id @default(uuid())
  email                String                    @unique
  passwordHash         String
  role                 Role                      @default(NGO_MEMBER)
  isVerified           Boolean                   @default(false)
  otpCode              String?
  otpExpiresAt         DateTime?
  refreshToken         String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  ngoId                String?
  companyId            String?
  auditLogs            AuditLog[]
  fundReleasesApproved FundRelease[]             @relation("FundReleasesApproved")
  messages             Message[]
  documentsUploaded    NgoDocument[]             @relation("DocumentsUploaded")
  documentsVerified    NgoDocument[]             @relation("DocumentsVerified")
  notifications        Notification[]
  assignedApplications OnboardingApplication[]   @relation("AssignedApplications")
  queriesRaised        OnboardingQuery[]         @relation("QueriesRaised")
  statusChanges        OnboardingStatusHistory[] @relation("StatusChanges")
  paymentOrdersCreated PaymentOrder[]            @relation("PaymentOrdersCreated")
  queryResponses       QueryResponse[]           @relation("QueryResponses")
  reportsCreated       Report[]
  riskFlagsResolved    RiskFlag[]                @relation("RiskFlagsResolved")
  riskScoresCalculated RiskScore[]               @relation("RiskScoresCalculated")
  company              Company?                  @relation(fields: [companyId], references: [id])
  ngo                  NGO?                      @relation(fields: [ngoId], references: [id])
  verificationsDone    VerificationCheck[]       @relation("VerificationsDone")
}

model NGO {
  id                    String                 @id @default(uuid())
  name                  String
  registrationNumber    String                 @unique
  darpanNumber          String?
  csr1Number            String?
  pan                   String                 @unique
  certificate12AUrl     String?
  certificate80GUrl     String?
  address               String
  state                 String                 @default("Maharashtra")
  district              String
  taluka                String
  village               String?
  website               String?
  socialLinks           Json?
  impactStatistics      Json?
  status                VerificationStatus     @default(PENDING)
  rejectionReason       String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  areasOfOperation      String[]
  city                  String?
  csrSectors            String[]
  displayName           String?
  officialEmail         String?
  officialPhone         String?
  organizationType      OrganizationType?
  pincode               String?
  registrationAuthority String?
  registrationDate      DateTime?
  yearEstablished       Int?
  bankAccounts          BankAccount[]
  chats                 Chat[]
  documents             Document[]
  governanceMembers     GovernanceMember[]
  ngoContacts           NgoContact[]
  ngoDocuments          NgoDocument[]
  onboardingApplication OnboardingApplication?
  projects              Project[]
  reports               Report[]
  riskScores            RiskScore[]
  users                 User[]
}

model Company {
  id              String             @id @default(uuid())
  name            String
  cin             String             @unique
  gst             String             @unique
  pan             String             @unique
  csrBudget       Decimal
  csrPolicyUrl    String?
  focusAreas      String[]
  contactInfo     Json
  status          VerificationStatus @default(PENDING)
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  chats           Chat[]
  documents       Document[]
  matchScores     MatchScore[]
  reports         Report[]
  users           User[]
}

model Project {
  id               String        @id @default(uuid())
  ngoId            String
  title            String
  description      String
  focusArea        String
  sdgGoal          String
  beneficiaryCount Int
  budgetRequested  Decimal
  budgetFunded     Decimal       @default(0)
  state            String        @default("Maharashtra")
  district         String
  taluka           String
  village          String?
  startDate        DateTime
  endDate          DateTime
  status           ProjectStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  chats            Chat[]
  documents        Document[]
  matchScores      MatchScore[]
  milestones       Milestone[]
  ngo              NGO           @relation(fields: [ngoId], references: [id], onDelete: Cascade)
}

model Milestone {
  id                 String          @id @default(uuid())
  projectId          String
  name               String
  description        String
  amount             Decimal
  dueDate            DateTime
  status             MilestoneStatus @default(PENDING)
  completionEvidence String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String     @id @default(uuid())
  projectId String?
  ngoId     String
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ngo       NGO        @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id])
  documents Document[]
  messages  Message[]

  @@unique([ngoId, companyId, projectId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  text      String?
  fileUrl   String?
  fileType  String?
  readBy    String[]
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])
}

model Document {
  id         String    @id @default(uuid())
  title      String
  fileUrl    String
  fileType   String
  expiryDate DateTime?
  ngoId      String?
  companyId  String?
  projectId  String?
  chatId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  chat       Chat?     @relation(fields: [chatId], references: [id])
  company    Company?  @relation(fields: [companyId], references: [id])
  ngo        NGO?      @relation(fields: [ngoId], references: [id])
  project    Project?  @relation(fields: [projectId], references: [id])
}

model MatchScore {
  id        String   @id @default(uuid())
  companyId String
  projectId String
  score     Int
  factors   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([companyId, projectId])
}

model Report {
  id          String     @id @default(uuid())
  title       String
  type        ReportType
  content     Json
  fileUrl     String?
  createdById String
  ngoId       String?
  companyId   String?
  createdAt   DateTime   @default(now())
  company     Company?   @relation(fields: [companyId], references: [id])
  createdBy   User       @relation(fields: [createdById], references: [id])
  ngo         NGO?       @relation(fields: [ngoId], references: [id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(IN_APP)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   Json
  ipAddress String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model OnboardingApplication {
  id                      String                    @id @default(uuid())
  ngoId                   String                    @unique
  legalName               String
  displayName             String?
  organizationType        OrganizationType
  registrationNumber      String
  registrationDate        DateTime
  registrationAuthority   String
  stateOfRegistration     String
  panNumber               String
  ngoDarpanId             String?
  csr1RegistrationNumber  String?
  yearEstablished         Int
  officialEmail           String
  officialPhone           String
  website                 String?
  headOfficeAddress       String
  state                   String
  district                String
  city                    String
  pincode                 String
  areasOfOperation        String[]
  csrSectors              String[]
  csr1Status              Boolean                   @default(false)
  has12A                  Boolean                   @default(false)
  has80G                  Boolean                   @default(false)
  gstRegistered           Boolean                   @default(false)
  gstin                   String?
  fcraStatus              String?
  fcraRegistrationNumber  String?
  founderDetails          Json?
  trusteesDirectors       Json?
  authorizedSignatory     Json?
  bankAccountHolder       String?
  bankName                String?
  bankBranch              String?
  bankAccountNumber       String?
  ifscCode                String?
  accountType             String?
  auditorName             String?
  auditorFirm             String?
  auditorContact          String?
  annualTurnover          Json?
  yearsOfOperation        Int?
  previousProjects        Json?
  beneficiaryCountLastFY  Int?
  staffCount              Int?
  volunteerCount          Int?
  blacklistDeclaration    Boolean                   @default(false)
  litigationDeclaration   Boolean                   @default(false)
  conflictOfInterest      Boolean                   @default(false)
  relatedPartyDeclaration Boolean                   @default(false)
  dataPrivacyConsent      Boolean                   @default(false)
  verificationConsent     Boolean                   @default(false)
  status                  OnboardingStatus          @default(DRAFT)
  completenessPercentage  Int                       @default(0)
  submittedAt             DateTime?
  reviewedAt              DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  assignedReviewerId      String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  assignedReviewer        User?                     @relation("AssignedApplications", fields: [assignedReviewerId], references: [id])
  ngo                     NGO                       @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  queries                 OnboardingQuery[]
  statusHistory           OnboardingStatusHistory[]
  verificationChecks      VerificationCheck[]
}

model OnboardingStatusHistory {
  id            String                @id @default(uuid())
  applicationId String
  fromStatus    OnboardingStatus?
  toStatus      OnboardingStatus
  changedById   String?
  reason        String?
  notes         String?
  createdAt     DateTime              @default(now())
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedBy     User?                 @relation("StatusChanges", fields: [changedById], references: [id])
}

model OnboardingQuery {
  id            String                @id @default(uuid())
  applicationId String
  raisedById    String
  queryText     String
  documentType  DocumentType?
  fieldName     String?
  status        QueryStatus           @default(OPEN)
  priority      String?
  dueDate       DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  raisedBy      User                  @relation("QueriesRaised", fields: [raisedById], references: [id])
  responses     QueryResponse[]
}

model QueryResponse {
  id             String          @id @default(uuid())
  queryId        String
  respondedById  String
  responseText   String
  attachmentUrls String[]
  createdAt      DateTime        @default(now())
  query          OnboardingQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  respondedBy    User            @relation("QueryResponses", fields: [respondedById], references: [id])
}

model VerificationCheck {
  id            String                @id @default(uuid())
  applicationId String
  checkType     String
  checkStatus   String
  checkResult   Json?
  verifiedById  String?
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy    User?                 @relation("VerificationsDone", fields: [verifiedById], references: [id])
}

model NgoDocument {
  id                String         @id @default(uuid())
  ngoId             String
  documentType      DocumentType
  title             String
  description       String?
  fileUrl           String
  fileName          String
  fileSize          Int
  fileType          String
  fileHash          String?
  status            DocumentStatus @default(UPLOADED)
  expiryDate        DateTime?
  issueDate         DateTime?
  issuingAuthority  String?
  documentNumber    String?
  verifiedById      String?
  verifiedAt        DateTime?
  verificationNotes String?
  rejectionReason   String?
  version           Int            @default(1)
  parentDocumentId  String?
  uploadedById      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ngo               NGO            @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  parentDocument    NgoDocument?   @relation("DocumentVersions", fields: [parentDocumentId], references: [id])
  childDocuments    NgoDocument[]  @relation("DocumentVersions")
  uploadedBy        User?          @relation("DocumentsUploaded", fields: [uploadedById], references: [id])
  verifiedBy        User?          @relation("DocumentsVerified", fields: [verifiedById], references: [id])

  @@index([ngoId, documentType])
  @@index([status])
  @@index([expiryDate])
}

model NgoContact {
  id          String   @id @default(uuid())
  ngoId       String
  contactType String
  name        String
  designation String?
  email       String
  phone       String
  mobile      String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ngo         NGO      @relation(fields: [ngoId], references: [id], onDelete: Cascade)
}

model GovernanceMember {
  id              String    @id @default(uuid())
  ngoId           String
  memberType      String
  name            String
  designation     String
  email           String?
  mobile          String?
  panNumber       String?
  aadhaarMasked   String?
  tenureStartDate DateTime?
  tenureEndDate   DateTime?
  isActive        Boolean   @default(true)
  idProofUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ngo             NGO       @relation(fields: [ngoId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id                 String         @id @default(uuid())
  ngoId              String
  accountHolderName  String
  bankName           String
  branchName         String
  accountNumber      String
  ifscCode           String
  accountType        String
  isPrimary          Boolean        @default(false)
  isVerified         Boolean        @default(false)
  verificationMethod String?
  verifiedAt         DateTime?
  cancelledChequeUrl String?
  bankStatementUrl   String?
  verificationNotes  String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  ngo                NGO            @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  fundReleases       FundRelease[]
  paymentOrders      PaymentOrder[]

  @@index([ngoId])
  @@index([accountNumber])
}

model RiskScore {
  id                     String     @id @default(uuid())
  ngoId                  String
  overallScore           Int
  riskLevel              RiskLevel
  legalRegistrationScore Int        @default(0)
  identitySignatoryScore Int        @default(0)
  financialScore         Int        @default(0)
  complianceScore        Int        @default(0)
  governanceScore        Int        @default(0)
  documentQualityScore   Int        @default(0)
  paymentBankScore       Int        @default(0)
  scoreBreakdown         Json?
  calculatedAt           DateTime   @default(now())
  calculatedById         String?
  riskFlags              RiskFlag[]
  calculatedBy           User?      @relation("RiskScoresCalculated", fields: [calculatedById], references: [id])
  ngo                    NGO        @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@index([ngoId])
  @@index([riskLevel])
}

model RiskFlag {
  id              String    @id @default(uuid())
  riskScoreId     String
  flagType        String
  severity        String
  description     String
  recommendation  String?
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedBy      User?     @relation("RiskFlagsResolved", fields: [resolvedById], references: [id])
  riskScore       RiskScore @relation(fields: [riskScoreId], references: [id], onDelete: Cascade)
}

model PaymentOrder {
  id               String               @id @default(uuid())
  orderNumber      String               @unique
  ngoId            String?
  companyId        String?
  projectId        String?
  bankAccountId    String?
  amount           Decimal
  currency         String               @default("INR")
  purpose          String
  description      String?
  status           PaymentStatus        @default(CREATED)
  gatewayName      String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  idempotencyKey   String               @unique
  metadata         Json?
  createdById      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  fundReleases     FundRelease[]
  bankAccount      BankAccount?         @relation(fields: [bankAccountId], references: [id])
  createdBy        User?                @relation("PaymentOrdersCreated", fields: [createdById], references: [id])
  transactions     PaymentTransaction[]
  webhookLogs      PaymentWebhookLog[]

  @@index([orderNumber])
  @@index([status])
  @@index([gatewayOrderId])
}

model PaymentTransaction {
  id                   String        @id @default(uuid())
  paymentOrderId       String
  transactionId        String        @unique
  gatewayTransactionId String?
  amount               Decimal
  currency             String        @default("INR")
  status               PaymentStatus
  paymentMethod        String?
  paymentDetails       Json?
  utrNumber            String?
  failureReason        String?
  failureCode          String?
  processedAt          DateTime?
  settledAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  paymentOrder         PaymentOrder  @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([status])
  @@index([utrNumber])
}

model PaymentWebhookLog {
  id               String        @id @default(uuid())
  paymentOrderId   String?
  gatewayName      String
  eventType        String
  webhookPayload   Json
  webhookSignature String?
  isSignatureValid Boolean?
  processedAt      DateTime?
  processingStatus String?
  processingError  String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime      @default(now())
  paymentOrder     PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([gatewayName, eventType])
  @@index([createdAt])
}

model FundRelease {
  id              String            @id @default(uuid())
  paymentOrderId  String
  ngoId           String?
  projectId       String?
  milestoneId     String?
  bankAccountId   String
  amount          Decimal
  currency        String            @default("INR")
  status          FundReleaseStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  releasedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  approvedBy      User?             @relation("FundReleasesApproved", fields: [approvedById], references: [id])
  bankAccount     BankAccount       @relation(fields: [bankAccountId], references: [id])
  paymentOrder    PaymentOrder      @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([ngoId])
  @@index([projectId])
}

enum Role {
  SUPER_ADMIN
  COMPANY_ADMIN
  COMPANY_MEMBER
  NGO_ADMIN
  NGO_MEMBER
  PORTAL_ADMIN
  CSR_ADMIN
  ANALYST_REVIEWER
  COMPLIANCE_REVIEWER
  FINANCE_USER
  APPROVER
  AUDITOR
  AUTHORIZED_SIGNATORY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum OrganizationType {
  TRUST
  SOCIETY
  SECTION_8_COMPANY
  GOVERNMENT_ENTITY
  OTHER
}

enum OnboardingStatus {
  DRAFT
  SUBMITTED
  AUTO_CHECK_PENDING
  AUTO_CHECK_PASSED
  AUTO_CHECK_FAILED
  UNDER_ANALYST_REVIEW
  QUERY_RAISED
  RESUBMITTED
  UNDER_COMPLIANCE_REVIEW
  APPROVAL_PENDING
  APPROVED
  CONDITIONALLY_APPROVED
  REJECTED
  SUSPENDED
  EXPIRED
  REVERIFICATION_DUE
}

enum DocumentType {
  REGISTRATION_CERTIFICATE
  TRUST_DEED
  MOA
  AOA
  SOCIETY_RULES
  PAN_CARD
  CSR1_CERTIFICATE
  CERTIFICATE_12A
  CERTIFICATE_80G
  CANCELLED_CHEQUE
  BANK_STATEMENT
  BANK_VERIFICATION_LETTER
  AUTHORIZED_SIGNATORY_PROOF
  BOARD_RESOLUTION
  AUTHORITY_LETTER
  TRUSTEE_LIST
  AUDITED_FINANCIAL_STATEMENT
  ANNUAL_REPORT
  DECLARATION_FORM
  CONSENT_FORM
  GST_CERTIFICATE
  FCRA_CERTIFICATE
  FCRA_PRIOR_PERMISSION
  FC4_RETURN
  FCRA_BANK_PROOF
  ITR7_ACKNOWLEDGEMENT
  FORM_10B
  FORM_10BB
  PROJECT_COMPLETION_CERTIFICATE
  DONOR_REFERENCE_LETTER
  LITIGATION_DOCUMENT
  POWER_OF_ATTORNEY
  NGO_DARPAN_CERTIFICATE
  OTHER
}

enum DocumentStatus {
  PENDING_UPLOAD
  UPLOADED
  UNDER_REVIEW
  VERIFIED
  REJECTED
  EXPIRED
  NEEDS_CORRECTION
}

enum QueryStatus {
  OPEN
  RESPONDED
  RESOLVED
  ESCALATED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PaymentStatus {
  CREATED
  PENDING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  UNDER_REVIEW
}

enum FundReleaseStatus {
  PENDING
  APPROVED
  RELEASED
  REJECTED
  ON_HOLD
}

enum ProjectStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  FUNDED
  COMPLETED
}

enum MilestoneStatus {
  PENDING
  APPROVED_BY_NGO
  APPROVED_BY_COMPANY
  RELEASED
}

enum ReportType {
  CSR
  IMPACT
  BENEFICIARY
  ANNUAL
}

enum NotificationType {
  EMAIL
  SMS
  IN_APP
}
