# ─────────────────────────────────────────────────────────────────────────────
# MahaCSR Backend — environment template
#
# Copy to `.env` for local development. Never commit real secrets.
# Values marked (REQUIRED IN PRODUCTION) MUST be set to real, non-default
# values before deploying — the server refuses to start otherwise
# (see src/config/env.ts → assertProductionEnv).
# ─────────────────────────────────────────────────────────────────────────────

# Use `development` locally. Set to `production` only in real deployments.
NODE_ENV=development
PORT=5000

# (REQUIRED IN PRODUCTION) PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/mahacsr

# Comma-separated allowed CORS origins / frontend URL(s)
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ─── Auth secrets ────────────────────────────────────────────────────────────
# (REQUIRED IN PRODUCTION) Generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server will NOT start in production if these are missing or left at the
# committed dev defaults.
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Master admin bootstrap ──────────────────────────────────────────────────
MASTER_ADMIN_EMAIL=admin@example.com
# Set a strong password only in your local/private .env — never commit a real one.
MASTER_ADMIN_PASSWORD=

# ─── Cloudinary (uploads) ────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=CSR

# ─── Redis (BullMQ notification queue) ───────────────────────────────────────
# Optional locally — without it, notifications process synchronously.
REDIS_URL=redis://USER:PASSWORD@HOST:6379

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@your-domain.com

# ─── SMS gateway ─────────────────────────────────────────────────────────────
# Provider selector: `stub` (default, dev/test) | `msg91`
SMS_PROVIDER=stub
# MSG91 config (REQUIRED when SMS_PROVIDER=msg91)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MAHCSR
# DLT-approved flow/template id registered with your DLT operator
MSG91_DLT_TEMPLATE_ID=
# API base + retry tuning (optional)
MSG91_BASE_URL=https://control.msg91.com/api/v5
MSG91_MAX_RETRIES=3
MSG91_RETRY_BASE_DELAY_MS=500
# Default country code for MSG91 (91 = India)
MSG91_DEFAULT_COUNTRY=91

# ─── SLA escalation cron ─────────────────────────────────────────────────────
# (REQUIRED IN PRODUCTION when using the serverless cron endpoint)
# Shared secret sent by Vercel Cron in the `x-cron-secret` header to authorize
# POST /api/admin/sla/cron. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
# In-process sweep interval for non-serverless hosts (ms). Default 1h.
SLA_SWEEP_INTERVAL_MS=3600000

# ─── API Setu (Government of India) — GST & Aadhaar verification ─────────────
APISETU_BASE_URL=https://apisetu.gov.in
APISETU_CLIENT_ID=your_apisetu_client_id
APISETU_CLIENT_SECRET=your_apisetu_client_secret
# Comma-separated list supports key rotation (first key is primary)
APISETU_API_KEY=your_apisetu_api_key
GST_VERIFY_ENDPOINT=/certificate/v3/gstn/gstvncer
AADHAAR_GENERATE_OTP_ENDPOINT=/aadhaar/v1/otp
AADHAAR_VERIFY_OTP_ENDPOINT=/aadhaar/v1/okyc
APISETU_REQUEST_TIMEOUT=15000
APISETU_MAX_RETRIES=2

# ─── Verification record encryption ──────────────────────────────────────────
# (REQUIRED IN PRODUCTION) 64 hex chars (32 bytes). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VERIFICATION_ENCRYPTION_KEY=

# Serve /api/verification/docs (Swagger UI) in production
ENABLE_API_DOCS=false

# Legacy NGO marketplace flow — keep disabled for the convergence model
ENABLE_LEGACY_NGO_MARKETPLACE=false
